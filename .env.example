# Copy this file to .env and fill in real values. .env is gitignored — never commit real secrets.

# SQLite connection string.
DATABASE_URL="file:./dev.db"

# Manager password for the /admin dashboard — full access (orders + menu
# management). Pick a real secret before deploying — this gates customer
# names/phones/addresses, and it is also the key that signs session cookies.
ADMIN_PASSWORD="change-me"

# Optional: staff password. Logging in with this grants an orders-only session —
# no menu editing, prices, or photo uploads (blocked at the routing layer, not
# just hidden). Leave unset to disable staff login entirely. Must be different
# from ADMIN_PASSWORD (if identical, that password grants manager).
# STAFF_PASSWORD="different-secret"
